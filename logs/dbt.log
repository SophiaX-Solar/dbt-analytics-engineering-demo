11:25:17.953008 [debug]: Query executed on node model.jaffle_shop.dim_customers:
create or replace transient  table RAW.jaffle_shop_xf.dim_customers
    
    
    
    as (with customers as (
    select * from RAW.jaffle_shop_xf.stg_jaffle_shop__customers
),
orders as (
    select * from RAW.jaffle_shop_xf.fct_orders
),
customer_orders as (
    select
        customer_id,
        min (order_date) as first_order_date,
        max (order_date) as most_recent_order_date,
        count(order_id) as number_of_orders,
        sum(amount) as lifetime_value
    from orders
    group by 1
),
 final as (
    select
        customers.customer_id,
        customers.first_name,
        customers.last_name,
        customer_orders.first_order_date,
        customer_orders.most_recent_order_date,
        coalesce (customer_orders.number_of_orders, 0) as number_of_orders,
        customer_orders.lifetime_value
    from customers
    left join customer_orders using (customer_id)
)
select * from final
    )

